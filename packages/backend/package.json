{
  "name": "@github-support/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API and agent pipeline for GitHub support system",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "db:seed": "node --env-file=../../.env --import tsx/esm src/db/seed.ts",
    "seed": "node --env-file=../../.env --import tsx/esm src/db/seed.ts",
    "ingest": "node --env-file=../../.env --import tsx/esm src/rag/ingest.ts",
    "scenarios:capture": "node --env-file=../../.env --import tsx/esm src/capture-scenarios.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "express": "^5.0.1",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.1",
    "openai": "^4.87.0",
    "node-fetch": "^3.3.2",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.7.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.0"
  }
}
